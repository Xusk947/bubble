BUBBLE_DOTENV=

BUBBLE_LOG_LEVEL=info
BUBBLE_LOG_DEVELOPMENT=false
BUBBLE_LOG_ENCODING=json
BUBBLE_LOG_STDOUT=true
BUBBLE_LOG_STDERR=false

BUBBLE_HTTP_ADDRESS=:8080
BUBBLE_HTTP_READ_TIMEOUT=15s
BUBBLE_HTTP_WRITE_TIMEOUT=15s
BUBBLE_HTTP_IDLE_TIMEOUT=60s
BUBBLE_HTTP_ENABLE_PPROF=false
BUBBLE_HTTP_ENABLE_CORS=false

BUBBLE_DB_DRIVER=
BUBBLE_DB_DSN=
BUBBLE_DB_ATLAS_URL=
BUBBLE_DB_MAX_OPEN_CONNS=10
BUBBLE_DB_MAX_IDLE_CONNS=5
BUBBLE_DB_CONN_MAX_LIFETIME=30m
BUBBLE_DB_AUTO_MIGRATE=false
BUBBLE_DB_MIGRATIONS_STRATEGY=atlas
BUBBLE_DB_MIGRATIONS_DIR=./migrations
BUBBLE_DB_MIGRATIONS_LOCK_ENABLED=true
BUBBLE_DB_MIGRATIONS_LOCK_KEY=424242

BUBBLE_CACHE_PROVIDER=local

BUBBLE_LOCAL_CACHE_MAX_ENTRIES=1024
BUBBLE_LOCAL_CACHE_DEFAULT_TTL=5m

BUBBLE_REDIS_ADDRESS=127.0.0.1:6379
BUBBLE_REDIS_USERNAME=
BUBBLE_REDIS_PASSWORD=
BUBBLE_REDIS_DB=0

BUBBLE_S3_ENDPOINT=
BUBBLE_S3_REGION=us-east-1
BUBBLE_S3_BUCKET=
BUBBLE_S3_ACCESS_KEY_ID=
BUBBLE_S3_SECRET_ACCESS_KEY=
BUBBLE_S3_SESSION_TOKEN=
BUBBLE_S3_USE_PATH_STYLE=false
BUBBLE_S3_DISABLE_TLS=false

BUBBLE_CRON_ENABLED=true

BUBBLE_QUEUE_PROVIDER=

BUBBLE_NATS_URL=nats://127.0.0.1:4222
BUBBLE_NATS_CREDS=
BUBBLE_NATS_STREAM=
BUBBLE_NATS_SUBJECT=
BUBBLE_NATS_DURABLE=
BUBBLE_NATS_ACK_WAIT=30s
BUBBLE_NATS_MAX_DELIVER=10
BUBBLE_NATS_ENSURE=true

BUBBLE_KAFKA_BROKERS=127.0.0.1:9092
BUBBLE_KAFKA_TOPIC=
BUBBLE_KAFKA_GROUP_ID=
